IDR_MAINFRAME MENU PRELOAD DISCARDABLE 
BEGIN
    POPUP "ﾌｧｲﾙ(&F)"
    BEGIN
        MENUITEM "新規作成(&N)\tCtrl+N",        ID_FILE_NEW
        MENUITEM "開く(&O)...\tCtrl+O",         ID_FILE_OPEN
        MENUITEM "上書き保存(&S)\tCtrl+S",      ID_FILE_SAVE
        MENUITEM "名前を付けて保存(&A)...",     ID_FILE_SAVE_AS
        MENUITEM SEPARATOR
        MENUITEM "ｳｨﾝﾄﾞｳを常に手前に(&T)",      ID_TOPMOST
        MENUITEM SEPARATOR
        MENUITEM "最新のﾌｧｲﾙ",                  ID_FILE_MRU_FILE1, GRAYED
        MENUITEM SEPARATOR
        MENUITEM "ｱﾌﾟﾘｹｰｼｮﾝの終了(&X)",         ID_APP_EXIT
    END
    POPUP "編集(&E)"
    BEGIN
        MENUITEM "元に戻す(&U)\tCtrl+Z",        ID_EDIT_UNDO
        MENUITEM "やり直し(&R)\tCtrl+Y",        ID_EDIT_REDO
        MENUITEM SEPARATOR
        MENUITEM "切り取り(&T)\tCtrl+X",        ID_EDIT_CUT
        MENUITEM "ｺﾋﾟｰ(&C)\tCtrl+C",            ID_EDIT_COPY
        MENUITEM "貼り付け(&P)\tCtrl+V",        ID_EDIT_PASTE
        MENUITEM "引用張付け(&H)",              ID_EDTL_REF_PAST
        MENUITEM SEPARATOR
        MENUITEM "ﾌﾘｰｶｰｿﾙ(&F)",                 ID_FREE_CUR
        MENUITEM "すべて選択(&A)\tCtrl+A",      ID_EDIT_SELECT_ALL
        MENUITEM SEPARATOR
        MENUITEM "編集ﾒﾆｭｰ(&E)\tCtrl+E",        ID_EDIT_MENU
    END
    POPUP "検索(&S)"
    BEGIN
        MENUITEM "検索(&F)...\tCtrl+F",         ID_EDIT_FIND
        MENUITEM "次を検索(&P)\tF3",            ID_EDIT_FIND_NEXT
        MENUITEM "前を検索(&N)\tShift+F3",      ID_EDIT_FIND_PREV
        MENUITEM SEPARATOR
        MENUITEM "置換(&R)\tCtrl+R",            ID_EDIT_REPLACE
        MENUITEM SEPARATOR
        MENUITEM "行ﾏｰｸ(&M)\tCtrl+M",           ID_MARK
        MENUITEM "次のﾏｰｸ(&D)\tF2",             ID_MARK_JUMP_NEXT
        MENUITEM "前のﾏｰｸ(&C)\tShift+F2",       ID_MARK_JUMP_PREV
        MENUITEM "行ﾏｰｸ全削除(&M)\tCtrl+Shift+M", ID_MARK_REMOVEALL
        MENUITEM SEPARATOR
        MENUITEM "行ｼﾞｬﾝﾌﾟ(&G)\tCtrl+G",        ID_JUMP
    END
    POPUP "表示(&V)"
    BEGIN
        MENUITEM "行折返し(&L)",                ID_LIMITCOL
        POPUP "行番号(&N)"
        BEGIN
            MENUITEM "行番号なし(&N)",              ID_LINENUM_NO
            MENUITEM "行番号あり(&L)",              ID_LINENUM_LINE
            MENUITEM "折返し行番号(&R)",            ID_LINENUM_ROW
        END
        MENUITEM SEPARATOR
        MENUITEM "ｽﾞｰﾑｲﾝ(&Z)",                  ID_ZOOM_IN
        MENUITEM "ｽﾞｰﾑｱｳﾄ(&O)",                 ID_ZOOM_OUT
        MENUITEM SEPARATOR
        MENUITEM "縦書表示(&V)",                ID_VERTICAL
        MENUITEM "編集ﾂｰﾙﾊﾞｰ(&T)",              ID_EDTL
        MENUITEM "編集記号(&H)",                ID_EDT_VIEW
        MENUITEM SEPARATOR
        MENUITEM "画面の再表示(&V)\tF8",        ID_REDRAW
    END
    POPUP "設定(&T)"
    BEGIN
        MENUITEM "設定ﾀﾞｲｱﾛｸﾞ(&C)...",          ID_CONFIG
        MENUITEM SEPARATOR
        MENUITEM "標準設定(&N)\tAlt+0",         ID_SELENV_NORMAL
    END
    POPUP "ﾍﾙﾌﾟ(&H)"
    BEGIN
        MENUITEM "ｵﾝﾗｲﾝﾍﾙﾌﾟ(\036C\037ﾓ)\tF1",   ID_HELP_INDEX
        MENUITEM SEPARATOR
        MENUITEM "ﾊﾞｰｼﾞｮﾝ情報(Mint) (&V)...",   ID_APP_ABOUT
        MENUITEM "ﾕｰｻﾞ-登録(\036U\037ﾕ)...",    IDR_CREJIT
    END
END

