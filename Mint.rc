IDD_ABOUTBOX DIALOGEX 0, 0, 218, 83
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "ﾊﾞｰｼﾞｮﾝ情報(Mint)"
FONT 9, "ＭＳ Ｐゴシック", 0, 0, 0x1
BEGIN
    ICON            IDR_MINTTYPE,IDC_STATIC,11,11,20,20
    LTEXT           "",IDC_STC_VERSION,40,10,119,14,SS_NOPREFIX
    RTEXT           "this mint is first release 1. - (1998.9/01)\nCopyright (C) 1998.5-9",
                    IDC_STATIC,48,24,120,20
    DEFPUSHBUTTON   "OK",IDOK,178,7,32,14,WS_GROUP
    EDITTEXT        IDC_EDT_INFO,36,44,156,36,ES_MULTILINE | ES_READONLY | 
                    ES_WANTRETURN,WS_EX_RIGHT
END

IDD_FIND DIALOG DISCARDABLE  0, 0, 230, 87
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "検索"
FONT 9, "ＭＳ Ｐゴシック"
BEGIN
    LTEXT           "検索(&N)",IDC_STATIC,4,12,31,8
    COMBOBOX        IDC_CMB_FIND,36,8,128,96,CBS_DROPDOWN | WS_VSCROLL | 
                    WS_TABSTOP
    LTEXT           "置換(&P)",IDC_STC_REPLACE,4,28,31,8
    COMBOBOX        IDC_CMB_REPLACE,36,24,128,96,CBS_DROPDOWN | WS_VSCROLL | 
                    WS_TABSTOP
    CONTROL         "大文字小文字を区別する(&C)",IDC_CHK_CASE,"Button",
                    BS_AUTOCHECKBOX | WS_TABSTOP,36,44,112,12
    PUSHBUTTON      "前を検索(&U)",IDC_DO_UP,172,24,50,14
    DEFPUSHBUTTON   "検索(&F)",IDC_DO_DOWN,172,8,50,14
    PUSHBUTTON      "置換(&R)",IDC_DO_REPLACE,172,24,50,14
    PUSHBUTTON      "全て置換(&A)",IDC_DO_REPLACE_ALL,172,44,50,14
    PUSHBUTTON      "ｷｬﾝｾﾙ",IDCANCEL,172,64,50,14
